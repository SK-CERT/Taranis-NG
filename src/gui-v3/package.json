{
  "name": "taranis-ng-gui-v3",
  "version": "26.02.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:remote": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "prebuild": "node scripts/update-version.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{js,vue,css,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,vue,css,scss,json}\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui --config=playwright.ui.config.js",
    "test:e2e:ui:remote": "playwright test --ui --ui-host=127.0.0.1 --ui-port=9323 --config=playwright.ui.config.js",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@primeuix/themes": "^2.0.3",
    "ae-cvss-calculator": "^1.0.11",
    "axios": "^1.7.9",
    "date-fns": "^4.1.0",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "quill": "^2.0.3",
    "vee-validate": "^4.14.11",
    "vue": "^3.5.13",
    "vue-i18n": "^11.2.8",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "sass": "^1.83.2",
    "vite": "^7.3.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,json,md}": [
      "prettier --write"
    ]
  }
}
